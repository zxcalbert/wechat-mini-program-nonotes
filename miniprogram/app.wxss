/**app.wxss**/

/* 亮色主题变量（默认） */
page, .theme-light {
  --backgroundColor: #ffffff;
  --textColor: #333333;
  --secondaryTextColor: #666666;
  --highlightColor: #8b4513;
  --borderColor: #f0f0f0;
  --cardBackgroundColor: #fdfaf2;
  --cardBorderColor: #e0d5b1;
  --warningBackgroundColor: #fff3cd;
  --warningBorderColor: #ffc107;
  --warningTextColor: #856404;
}

/* 强制暗色主题 */
.theme-dark {
  --backgroundColor: #121212 !important;
  --textColor: #e0e0e0 !important;
  --secondaryTextColor: #999999 !important;
  --highlightColor: #d4a574 !important;
  --borderColor: #333333 !important;
  --cardBackgroundColor: #1e1e1e !important;
  --cardBorderColor: #444444 !important;
  --warningBackgroundColor: #3d3d00 !important;
  --warningBorderColor: #666600 !important;
  --warningTextColor: #e0e000 !important;
}

/* 系统主题跟随 - 媒体查询 */
@media (prefers-color-scheme: dark) {
  page:not(.theme-light):not(.theme-dark) {
    --backgroundColor: #121212;
    --textColor: #e0e0e0;
    --secondaryTextColor: #999999;
    --highlightColor: #d4a574;
    --borderColor: #333333;
    --cardBackgroundColor: #1e1e1e;
    --cardBorderColor: #444444;
    --warningBackgroundColor: #3d3d00;
    --warningBorderColor: #666600;
    --warningTextColor: #e0e000;
  }
}

/* 基础页面样式 */
page {
  background-color: var(--backgroundColor, #f6f6f6);
  color: var(--textColor, #333333);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* 字体大小设置 */
.font-small {
  font-size: 24rpx !important;
}
.font-small .reply-text,
.font-small .letter-content {
  font-size: 26rpx !important;
  line-height: 1.7 !important;
}
.font-small .note-content-preview {
  font-size: 12px !important;
}

.font-large {
  font-size: 32rpx !important;
}
.font-large .reply-text,
.font-large .letter-content {
  font-size: 36rpx !important;
  line-height: 2 !important;
}
.font-large .note-content-preview {
  font-size: 16px !important;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}

/* 脑图全局样式（detail/incubatorResult/structureAnalysisResult 共用） */
.mindmap-section {
  margin-top: 30rpx;
  padding: 0 10rpx;
}

.mindmap-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 24rpx 0;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.mindmap-btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.mindmap-btn-text {
  font-size: 30rpx;
  font-weight: 500;
}

.mindmap-error {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.mindmap-retry {
  color: #667eea;
  text-decoration: underline;
}

.mindmap-result {
  margin-top: 20rpx;
}

.mindmap-save-btn {
  text-align: center;
  padding: 20rpx;
  color: #666;
  font-size: 26rpx;
  margin-top: 16rpx;
}