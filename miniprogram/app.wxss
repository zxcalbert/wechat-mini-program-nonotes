/**app.wxss**/
page {
  background-color: var(--backgroundColor, #f6f6f6);
  color: var(--textColor, #333333);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}