
/* pages/login/login.wxss */
page {
  background-color: var(--borderColor, #f7f7f7);
}

.login-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, var(--borderColor, #f7f7f7) 0%, var(--backgroundColor, #ffffff) 100%);
}

.user-info-section {
  display: flex;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  background-color: var(--backgroundColor, #ffffff);
  border-bottom: 1rpx solid var(--borderColor, #f0f0f0);
}

.avatar-wrapper {
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid var(--highlightColor, #8b4513);
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--textColor, #333);
  margin-bottom: 10rpx;
}

.location {
  font-size: 24rpx;
  color: var(--secondaryTextColor, #999);
}

.info-card {
  margin: 40rpx 30rpx;
  padding: 30rpx;
  background-color: var(--cardBackgroundColor, #fdfaf2);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--highlightColor, #8b4513);
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--highlightColor, #8b4513);
  margin-bottom: 15rpx;
}

.info-text {
  display: block;
  font-size: 26rpx;
  color: var(--secondaryTextColor, #666);
  line-height: 1.8;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 30rpx 40rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--textColor, #333);
  margin-bottom: 10rpx;
}

.slogan {
  font-size: 28rpx;
  color: var(--highlightColor, #8b4513);
  font-weight: 500;
}

.intro-section {
  margin: 50rpx 30rpx;
  padding: 30rpx;
  background-color: var(--backgroundColor, #ffffff);
  border-radius: 12rpx;
}

.intro-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid var(--borderColor, #f0f0f0);
}

.intro-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.intro-icon {
  display: block;
  font-size: 44rpx;
  margin-right: 20rpx;
  min-width: 50rpx;
}

.intro-text {
  font-size: 28rpx;
  color: var(--textColor, #333);
  line-height: 1.5;
}

.privacy-notice {
  margin: 0 30rpx;
  padding: 25rpx;
  background-color: var(--borderColor, #f5f5f5);
  border-radius: 8rpx;
  border-left: 3rpx solid var(--borderColor, #ccc);
}

.notice-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--secondaryTextColor, #666);
  margin-bottom: 10rpx;
}

.notice-text {
  display: block;
  font-size: 22rpx;
  color: var(--secondaryTextColor, #999);
  line-height: 1.6;
}

.btn {
  margin: 20rpx 30rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  background-color: var(--borderColor, #f0f0f0);
  color: var(--secondaryTextColor, #999);
}

.btn-login {
  margin-top: auto;
  margin-bottom: 40rpx;
  background-color: var(--highlightColor, #8b4513);
  color: #ffffff;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-login:active {
  background-color: #6b3410;
}

.btn-primary {
  background-color: var(--highlightColor, #8b4513);
  color: #ffffff;
  margin-top: 30rpx;
}

.btn-primary:active {
  background-color: #6b3410;
}

.btn-logout {
  background-color: var(--borderColor, #f0f0f0);
  color: var(--secondaryTextColor, #999);
}

.btn-logout:active {
  background-color: var(--borderColor, #e0e0e0);
}

