
/* pages/detail/detail.wxss */
page {
  background-color: var(--borderColor, #f0f0f0);
  padding: 30rpx;
}

.letter-paper {
  background-color: var(--cardBackgroundColor, #fdfaf2);
  padding: 50rpx;
  min-height: 600rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  border: 1rpx solid var(--cardBorderColor, #e0d5b1);
}

.letter-text {
  font-size: 32rpx;
  line-height: 2;
  color: var(--textColor, #333);
  word-break: break-all;
}

.reply-container {
  margin-top: 50rpx;
  padding-bottom: 100rpx;
}

.ai-disclaimer {
  background-color: var(--warningBackgroundColor, #fff3cd);
  border: 1rpx solid var(--warningBorderColor, #ffc107);
  border-radius: 8rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: var(--warningTextColor, #856404);
  line-height: 1.5;
}

.reply-card {
  background-color: var(--backgroundColor, #ffffff);
  border-left: 10rpx solid #27ae60;
  padding: 40rpx 40rpx 60rpx 40rpx;
  border-radius: 4rpx;
  margin-bottom: 30rpx;
}

.reply-badge {
  color: #27ae60;
  font-weight: bold;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.reply-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #27ae60;
  margin-bottom: 30rpx;
}

.reply-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--textColor, #333);
  word-break: break-all;
  display: block;
  margin-bottom: 40rpx;
}

.reply-signature {
  text-align: right;
  padding-top: 30rpx;
  border-top: 1rpx solid var(--borderColor, #e0e0e0);
}

.signature-text {
  font-size: 28rpx;
  color: var(--secondaryTextColor, #666);
  font-style: italic;
}

.waiting-card {
  text-align: center;
  padding: 60rpx;
  color: var(--secondaryTextColor, #999);
}

