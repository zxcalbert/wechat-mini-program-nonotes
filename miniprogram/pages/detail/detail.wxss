
/* pages/detail/detail.wxss */
page {
  background-color: var(--borderColor, #f0f0f0);
  padding: 30rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  max-width: 100vw;
}

.container {
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

.letter-paper {
  background-color: var(--cardBackgroundColor, #fdfaf2);
  padding: 50rpx;
  min-height: 600rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  border: 1rpx solid var(--cardBorderColor, #e0d5b1);
  box-sizing: border-box;
  overflow: hidden;
}

.letter-header {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--borderColor, #e0e0e0);
}

.mentor-name {
  font-size: 28rpx;
  color: var(--highlightColor, #8b4513);
  font-weight: 600;
  word-break: break-word;
}

.letter-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--textColor, #333);
  word-break: break-word;
  overflow-wrap: break-word;
  box-sizing: border-box;
}

.letter-footer {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--borderColor, #e0e0e0);
  text-align: right;
}

.date {
  font-size: 24rpx;
  color: var(--secondaryTextColor, #999);
}

.letter-text {
  font-size: 32rpx;
  line-height: 2;
  color: var(--textColor, #333);
  word-break: break-all;
}

.reply-container {
  margin-top: 50rpx;
  padding-bottom: 100rpx;
}

.reply-zone {
  margin-top: 30rpx;
  padding-bottom: 60rpx;
  overflow: hidden;
}

.ai-disclaimer {
  background-color: var(--warningBackgroundColor, #fff3cd);
  border: 1rpx solid var(--warningBorderColor, #ffc107);
  border-radius: 8rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: var(--warningTextColor, #856404);
  line-height: 1.5;
  word-break: break-word;
}

.reply-card {
  background-color: var(--backgroundColor, #ffffff);
  border-left: 10rpx solid #27ae60;
  padding: 40rpx;
  border-radius: 4rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.reply-badge {
  color: #27ae60;
  font-weight: bold;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.reply-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #27ae60;
  margin-bottom: 30rpx;
}

.reply-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--textColor, #333);
  word-break: break-word;
  overflow-wrap: break-word;
  display: block;
  margin-bottom: 40rpx;
}

.reply-signature {
  text-align: right;
  padding-top: 30rpx;
  border-top: 1rpx solid var(--borderColor, #e0e0e0);
}

.signature-text {
  font-size: 28rpx;
  color: var(--secondaryTextColor, #666);
  font-style: italic;
}

.waiting-card {
  text-align: center;
  padding: 60rpx;
  color: var(--secondaryTextColor, #999);
}

.waiting-hint {
  text-align: center;
  padding: 60rpx 30rpx;
  color: var(--secondaryTextColor, #999);
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

/* 导出 Markdown 按钮 */
.export-section {
  margin-top: 20rpx;
  padding: 0;
}

.export-btn {
  background-color: var(--backgroundColor, #f8f9fa);
  border: 1rpx solid var(--borderColor, #dee2e6);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--secondaryTextColor, #6c757d);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.report-btn {
  background-color: #d93025;
  color: #ffffff;
}

.report-btn text {
  color: #ffffff;
}
