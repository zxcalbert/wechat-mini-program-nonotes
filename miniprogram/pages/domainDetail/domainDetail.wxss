page {
  background-color: var(--borderColor, #f5f5f5);
}

.container {
  padding: 16rpx 24rpx 100rpx;
}

/* 领域横幅 */
.domain-banner {
  display: flex;
  align-items: center;
  background: var(--backgroundColor, #fff);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.domain-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.domain-info {
  display: flex;
  flex-direction: column;
}

.domain-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--textColor, #333);
}

.domain-count {
  font-size: 24rpx;
  color: var(--secondaryTextColor, #999);
  margin-top: 4rpx;
}

/* 分节标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--textColor, #333);
  margin: 24rpx 0 12rpx;
}

/* 方法卡片 */
.method-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.method-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--backgroundColor, #fff);
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
  transition: opacity 0.2s;
}

.method-card:active {
  opacity: 0.8;
}

.method-name {
  font-size: 28rpx;
  color: var(--textColor, #333);
  flex: 1;
}

.method-arrow {
  font-size: 24rpx;
  color: var(--secondaryTextColor, #ccc);
  margin-left: 12rpx;
}

/* 历史分析卡片 */
.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.analysis-card {
  background: var(--backgroundColor, #fff);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.analysis-card:active {
  opacity: 0.85;
}

.analysis-content {
  font-size: 26rpx;
  color: var(--textColor, #333);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.analysis-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.analysis-method {
  font-size: 22rpx;
  color: var(--secondaryTextColor, #666);
  background: var(--borderColor, #f0f0f0);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.analysis-date {
  font-size: 22rpx;
  color: var(--secondaryTextColor, #999);
}
