.profile-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  height: 100%;
  background: linear-gradient(180deg, var(--borderColor, #f7f7f7) 0%, var(--backgroundColor, #ffffff) 100%);
  box-sizing: border-box;
}

.header-section {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: var(--backgroundColor, #ffffff);
  position: relative;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.back-icon {
  font-size: 40rpx;
  color: var(--textColor, #333);
  font-weight: 600;
}

.page-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--textColor, #333);
  text-align: center;
}

.scroll-content {
  flex: 1;
  overflow-y: auto;
  box-sizing: border-box;
}

.content-section {
  margin: 30rpx;
}

.avatar-section,
.nickname-section {
  background-color: var(--backgroundColor, #ffffff);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--textColor, #333);
  margin-bottom: 20rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-button {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  border: none;
  background: transparent;
  line-height: 1;
  margin-bottom: 15rpx;
}

.avatar-button::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx solid var(--highlightColor, #8b4513);
}

.avatar-hint {
  font-size: 24rpx;
  color: var(--secondaryTextColor, #999);
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: var(--borderColor, #f5f5f5);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--textColor, #333);
  box-sizing: border-box;
}

.tip-section {
  background-color: var(--cardBackgroundColor, #fdfaf2);
  border-radius: 8rpx;
  border-left: 3rpx solid var(--highlightColor, #8b4513);
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.fix-section {
  background-color: var(--backgroundColor, #ffffff);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 2rpx dashed var(--highlightColor, #8b4513);
}

.fix-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--textColor, #333);
  margin-bottom: 12rpx;
}

.fix-desc {
  display: block;
  font-size: 24rpx;
  color: var(--secondaryTextColor, #666);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--highlightColor, #8b4513);
  text-align: center;
}

.btn {
  margin: 30rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-save {
  background-color: var(--highlightColor, #8b4513);
  color: #ffffff;
}

.btn-fix {
  margin: 0;
  background-color: #fff7ec;
  color: var(--highlightColor, #8b4513);
  border: 2rpx solid var(--highlightColor, #8b4513);
}

.btn-save:active {
  background-color: #6b3410;
}
