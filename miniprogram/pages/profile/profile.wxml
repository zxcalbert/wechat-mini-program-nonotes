<view class="profile-container {{themeClass}}">
  <view class="header-section">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="page-title">个人信息</text>
  </view>

  <scroll-view class="scroll-content" scroll-y="true">
    <view class="content-section">
      <view class="avatar-section">
        <text class="section-title">头像</text>
        <button class="avatar-button" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{avatarUrl}}" mode="aspectFill"></image>
        </button>
        <text class="avatar-hint">点击更换头像</text>
      </view>

      <view class="nickname-section">
        <text class="section-title">昵称</text>
        <input 
          type="nickname" 
          class="nickname-input" 
          placeholder="请输入昵称" 
          value="{{nickname}}"
          bind:input="onNicknameInput"
          maxlength="20"
        />
      </view>

      <view class="tip-section">
        <text class="tip-text">完善个人信息可获得更好的体验</text>
      </view>
    </view>

    <button 
      class="btn btn-save"
      bindtap="saveProfile"
      loading="{{loading}}"
    >
      <text>保存</text>
    </button>
  </scroll-view>
</view>
