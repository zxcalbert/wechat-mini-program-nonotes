&lt;view class="container {{themeClass}}"&gt;
  &lt;scroll-view scroll-y="true" class="write-content"&gt;
    &lt;view wx:if="{{needReply}}" class="selector-group"&gt;
      &lt;picker bindchange="onMentorChange" value="{{mentorIndex}}" range="{{mentors}}"&gt;
        &lt;view class="picker-item"&gt;
          &lt;text class="picker-label"&gt;指引导师：&lt;/text&gt;
          &lt;text class="highlight"&gt;{{mentors[mentorIndex]}}&lt;/text&gt;
          &lt;text class="picker-arrow"&gt;▼&lt;/text&gt;
          &lt;text class="picker-hint"&gt;点击选择&lt;/text&gt;
        &lt;/view&gt;
      &lt;/picker&gt;
      &lt;view class="guide-btn" bindtap="showMentorGuideHandler"&gt;
        &lt;text class="guide-icon"&gt;ℹ️&lt;/text&gt;
        &lt;text class="guide-text"&gt;查看说明&lt;/text&gt;
      &lt;/view&gt;
    &lt;/view&gt;

    &lt;!-- AI助手说明弹窗 --&gt;
    &lt;view wx:if="{{showMentorGuide}}" class="guide-modal" catchtap="closeMentorGuide"&gt;
      &lt;view class="guide-content" catchtap=""&gt;
        &lt;view class="guide-header"&gt;
          &lt;text class="guide-title"&gt;{{mentors[mentorIndex]}} - 核心原则&lt;/text&gt;
          &lt;text class="guide-close" bindtap="closeMentorGuide"&gt;✕&lt;/text&gt;
        &lt;/view&gt;
        &lt;scroll-view scroll-y="true" class="guide-body"&gt;
          &lt;text class="guide-text"&gt;{{currentMentorGuide}}&lt;/text&gt;
        &lt;/scroll-view&gt;
      &lt;/view&gt;
    &lt;/view&gt;

    &lt;view wx:if="{{hasSensitiveWarning}}" class="sensitive-warning"&gt;
      &lt;text class="warning-icon"&gt;⚠️&lt;/text&gt;
      &lt;text class="warning-text"&gt;{{sensitiveWarning}}&lt;/text&gt;
    &lt;/view&gt;

    &lt;view class="letter-paper"&gt;
      &lt;view class="header"&gt;
        &lt;text class="to" wx:if="{{needReply}}"&gt;致：{{mentors[mentorIndex]}}&lt;/text&gt;
        &lt;text class="to" wx:else&gt;我的思考&lt;/text&gt;
        &lt;text class="date"&gt;{{currentDate}}&lt;/text&gt;
      &lt;/view&gt;
      
      &lt;textarea 
        class="content-area" 
        placeholder="{{needReply ? mentors[mentorIndex] + '先生，您好！我有些思考想与你分享...' : '记录我的思考...'}}" 
        maxlength="5000"
        bindinput="onInput"
        value="{{content}}"
      /&gt;
    &lt;/view&gt;

    &lt;!-- 邮票选择 --&gt;
    &lt;view class="stamp-section"&gt;
      &lt;view class="stamp-title"&gt;📮 需要大师回信吗？&lt;/view&gt;
      &lt;view class="stamp-options"&gt;
        &lt;view class="stamp-option {{needReply === false ? 'selected' : ''}}" bindtap="selectNeedReply" data-need="{{false}}"&gt;
          &lt;text class="option-text"&gt;无需回复&lt;/text&gt;
          &lt;text class="option-desc"&gt;自己思考就好&lt;/text&gt;
        &lt;/view&gt;
        &lt;view class="stamp-option {{needReply === true ? 'selected' : ''}}" bindtap="selectNeedReply" data-need="{{true}}"&gt;
          &lt;text class="option-text"&gt;需要回信&lt;/text&gt;
          &lt;text class="option-desc"&gt;使用邮票 ({{userStamps}}/2)&lt;/text&gt;
        &lt;/view&gt;
      &lt;/view&gt;
      
      &lt;view wx:if="{{needReply &amp;&amp; userStamps === 0}}" class="warn-section"&gt;
        &lt;text class="warn-text"&gt;⚠️ 免费邮票已用完，需购买邮票才能获得大师回信&lt;/text&gt;
        &lt;button class="buy-stamps-btn" bindtap="buyStamps"&gt;购买邮票&lt;/button&gt;
      &lt;/view&gt;

      &lt;view wx:if="{{needReply &amp;&amp; userStamps === 1}}" class="warn-section tip-section"&gt;
        &lt;text class="warn-text"&gt;💡 邮票即将用完（剩余1张），建议提前购买&lt;/text&gt;
        &lt;button class="buy-stamps-btn" bindtap="buyStamps"&gt;购买邮票&lt;/button&gt;
      &lt;/view&gt;

      &lt;view wx:if="{{needReply}}" class="reply-info"&gt;
        &lt;text class="info-title"&gt;回信说明：&lt;/text&gt;
        &lt;text class="info-text"&gt;• 每个用户拥有2张免费邮票&lt;/text&gt;
        &lt;text class="info-text"&gt;• 请求回信后，需等待18小时才能收到&lt;/text&gt;
        &lt;text class="info-text"&gt;• 这个机制可帮助你深入思考和写作&lt;/text&gt;
      &lt;/view&gt;
    &lt;/view&gt;
  &lt;/scroll-view&gt;

  &lt;view class="send-buttons"&gt;
    &lt;button class="send-btn {{!canSend ? 'disabled' : ''}}" bindtap="submitLetter" disabled="{{!canSend}}"&gt;
      {{needReply ? '📮 寄出并请求回信' : '📝 寄出笔记'}}
    &lt;/button&gt;
  &lt;/view&gt;
&lt;/view&gt;
