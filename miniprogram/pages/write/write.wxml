<view class="page">
  <view class="hero">
    <view class="eyebrow">深度思考工具</view>
    <view class="title">分析方法</view>
    <view class="subtitle">输入一个问题或想法，选择分析方法，获得结构化分析结果。</view>
  </view>

  <view class="panel" wx:if="{{needReply}}">
    <view class="label">选择分析方法</view>
    <view class="method-fields">
      <view wx:for="{{methodFields}}" wx:key="key" class="method-field">
        <view class="field-header">
          <text class="field-icon">{{item.icon}}</text>
          <text class="field-name">{{item.name}}</text>
        </view>
        <view class="method-tags">
          <view
            wx:for="{{item.methods}}"
            wx:for-item="method"
            wx:key="*this"
            class="method-tag {{selectedMethodMap[method] ? 'selected' : ''}}"
            data-method="{{method}}"
            bindtap="toggleMethod"
          >{{method}}</view>
        </view>
      </view>
    </view>
    <view class="selected-info">
      <view class="selected-count">
        <text class="count-label">已选方法</text>
        <text class="count-number">{{selectedMethod ? '1/1' : '0/1'}}</text>
      </view>
      <view class="selected-list">
        <text>{{selectedMethod || '请点击上方方法标签进行选择'}}</text>
      </view>
    </view>
    <view class="guide-btn" bindtap="showMethodGuideHandler">
      <text class="guide-icon">ℹ️</text>
      <text class="guide-text">查看方法说明</text>
    </view>
  </view>

  <!-- 分析方法说明弹窗 -->
  <view wx:if="{{showMethodGuide}}" class="guide-modal" catchtap="closeMethodGuide">
    <view class="guide-content" catchtap="">
      <view class="guide-header">
        <text class="guide-title">{{selectedMethod}} - 核心框架</text>
        <text class="guide-close" bindtap="closeMethodGuide">✕</text>
      </view>
      <scroll-view scroll-y="true" class="guide-body">
        <text class="guide-text">{{currentMethodGuide}}</text>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{hasSensitiveWarning}}" class="sensitive-warning">
    <text class="warning-icon">⚠️</text>
    <text class="warning-text">{{sensitiveWarning}}</text>
  </view>

  <view class="panel">
    <view class="label">{{needReply ? '需要分析的内容' : '我的思考'}}</view>
    <textarea
      class="content-input"
      placeholder="{{needReply ? '请输入需要分析的问题或内容...' : '记录我的思考...'}}"
      maxlength="5000"
      bindinput="onInput"
      value="{{content}}"
    />
  </view>

  <view class="panel">
    <view class="label">分析选项</view>
    <view class="stamp-options">
      <view class="stamp-option {{needReply === false ? 'selected' : ''}}" bindtap="selectNeedReply" data-need="{{false}}">
        <text class="option-text">无需分析</text>
        <text class="option-desc">仅保存笔记</text>
      </view>
      <view class="stamp-option {{needReply === true ? 'selected' : ''}}" bindtap="selectNeedReply" data-need="{{true}}">
        <text class="option-text">需要分析</text>
        <text class="option-desc">使用AI分析</text>
      </view>
    </view>

    <view wx:if="{{needReply && userStamps <= 1}}">
      <view wx:if="{{userStamps === 0}}" class="warn-section">
        <text class="warn-text">⚠️ 免费额度已用完，需购买额度才能使用AI分析</text>
        <button class="buy-stamps-btn" bindtap="buyStamps">购买额度</button>
      </view>
      <view wx:if="{{userStamps === 1}}" class="warn-section tip-section">
        <text class="warn-text">💡 额度即将用完（剩余1次），建议提前购买</text>
        <button class="buy-stamps-btn" bindtap="buyStamps">购买额度</button>
      </view>
    </view>

    <view wx:if="{{needReply}}" class="reply-info">
      <text class="info-title">分析说明：</text>
      <text class="info-text">• 每个用户拥有2次免费分析额度</text>
      <text class="info-text">• 提交分析请求后，需等待18小时才能查看结果</text>
      <text class="info-text">• 这个机制可帮助你深入思考和沉淀</text>
    </view>
  </view>

  <view class="send-buttons">
    <button class="send-btn {{!canSend ? 'disabled' : ''}}" bindtap="submitLetter" disabled="{{!canSend}}">
      {{needReply ? '🔍 提交分析请求' : '📝 保存笔记'}}
    </button>
  </view>
</view>
