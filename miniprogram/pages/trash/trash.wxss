
.container {
  min-height: 100vh;
  background-color: var(--borderColor, #f5f5f5);
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-left: 30rpx;
  padding-right: 30rpx;
  background-color: var(--backgroundColor, #ffffff);
  border-bottom: 1rpx solid var(--borderColor, #e0e0e0);
}

.header-left {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 48rpx;
  color: var(--textColor, #333);
  margin-right: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--textColor, #333);
}

.empty-btn {
  font-size: 28rpx;
  color: #ff4d4f;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--secondaryTextColor, #999);
}

.notes-list {
  flex: 1;
  padding: 20rpx;
}

.note-card {
  background-color: var(--backgroundColor, #ffffff);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.note-main {
  margin-bottom: 20rpx;
}

.note-content-preview {
  font-size: 30rpx;
  color: var(--textColor, #333);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 15rpx;
}

.note-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.note-date {
  font-size: 24rpx;
  color: var(--secondaryTextColor, #999);
}

.note-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  background-color: var(--borderColor, #f0f0f0);
  color: var(--secondaryTextColor, #666);
  border-radius: 8rpx;
}

.note-actions {
  display: flex;
  gap: 15rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid var(--borderColor, #f0f0f0);
}

.action-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.restore-btn {
  background-color: #52c41a;
  color: #ffffff;
  border: none;
}

.delete {
  background-color: #ff4d4f;
  color: #ffffff;
  border: none;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: var(--secondaryTextColor, #999);
  font-size: 28rpx;
}

