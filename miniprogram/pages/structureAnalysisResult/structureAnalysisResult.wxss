page {
  background-color: var(--backgroundColor, #ffffff);
}

.container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  background-color: var(--backgroundColor, #ffffff);
  padding-top: env(safe-area-inset-top);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 10px;
  padding-right: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--borderColor, #f0f0f0);
  background-color: var(--backgroundColor, #ffffff);
}

.back-btn {
  font-size: 24px;
  padding: 8px 10px;
  cursor: pointer;
  color: var(--textColor, #000000);
}

.back-icon {
  font-size: 28px;
}

.header-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--textColor, #000000);
  flex: 1;
  text-align: center;
}

.header-spacer {
  width: 40px;
}

.content {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
}

.user-question {
  margin-bottom: 24px;
  padding: 16px;
  background-color: #f3e5f5;
  border: 1px solid #e1bee7;
  border-radius: 8px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--textColor, #000000);
  margin-bottom: 12px;
}

.question-text {
  font-size: 15px;
  line-height: 1.8;
  color: var(--textColor, #333333);
}

.type-tag {
  margin-top: 12px;
  display: inline-block;
}

.tag-text {
  display: inline-block;
  padding: 4px 12px;
  background-color: #7b1fa2;
  color: #ffffff;
  font-size: 13px;
  border-radius: 12px;
}

.dimensions-section {
  margin-bottom: 24px;
  padding: 16px;
  background-color: #f0f7ff;
  border: 1px solid #b8d4f0;
  border-radius: 8px;
}

.dimensions-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.dimension-tag {
  display: inline-block;
  padding: 4px 12px;
  background-color: #7b1fa2;
  color: #ffffff;
  font-size: 13px;
  border-radius: 12px;
}

.report-section {
  margin-bottom: 24px;
  padding: 16px;
  background-color: var(--cardBackgroundColor, #fefefe);
  border: 1px solid var(--cardBorderColor, #e8e8e8);
  border-radius: 8px;
}

.report-content {
  font-size: 15px;
  line-height: 1.8;
  color: var(--textColor, #333333);
  white-space: pre-wrap;
}

.action-buttons {
  display: flex;
  gap: 12px;
}

.action-btn {
  flex: 1;
  padding: 14px;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 600;
}

.export-btn {
  background-color: #7b1fa2;
  color: #ffffff;
}

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--borderColor, #e0e0e0);
  border-top-color: #7b1fa2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 16px;
  font-size: 15px;
  color: var(--textColor, #666666);
}

.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  color: var(--textColor, #666666);
}
