<view class="container {{themeClass}} {{fontClass}}">
  <view class="header" style="padding-top: {{statusBarHeight + 10}}px;">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">{{data.analysisType === 'product' ? '产品分析' : '公司分析'}}</view>
    <view class="header-spacer"></view>
  </view>

  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{data}}" class="content">
    <view class="user-question">
      <view class="section-title">🔬 分析对象</view>
      <view class="question-text">{{data.content}}</view>
      <view class="type-tag">
        <text class="tag-text">{{data.analysisType === 'product' ? '产品分析' : '公司分析'}}</text>
      </view>
    </view>

    <view wx:if="{{data.dimensions && data.dimensions.length > 0}}" class="dimensions-section">
      <view class="section-title">📊 分析维度</view>
      <view class="dimensions-container">
        <text wx:for="{{data.dimensions}}" wx:key="*this" class="dimension-tag">{{item}}</text>
      </view>
    </view>

    <view class="report-section">
      <view class="section-title">📋 分析报告</view>
      <markdown-renderer content="{{data.report}}" />
    </view>

    <view class="ai-disclaimer">
      <text class="disclaimer-text">⚠️ AI 生成内容仅供参考，不代表任何特定个人或机构的观点</text>
    </view>

    <view class="mindmap-section" wx:if="{{data.report}}">
      <view class="mindmap-btn" bindtap="generateMindmap">
        <text class="mindmap-btn-icon">🧠</text>
        <text class="mindmap-btn-text">{{mindmapLoading ? '生成中...' : '生成可视化脑图'}}</text>
      </view>

      <view wx:if="{{mindmapError}}" class="mindmap-error">
        <text>生成失败，</text>
        <text class="mindmap-retry" bindtap="generateMindmap">点击重试</text>
      </view>

      <view wx:if="{{mindmapData}}" class="mindmap-result">
        <mindmap-renderer id="mindmapRenderer" nodeData="{{mindmapData}}" />
        <view class="mindmap-save-btn" bindtap="saveMindmapImage">
          <text>💾 保存截图</text>
        </view>
      </view>
    </view>

    <view class="action-buttons">
      <button class="action-btn export-btn" bindtap="exportText">
        导出文本
      </button>
    </view>
  </view>

  <view wx:else class="empty-container">
    <text class="empty-icon">📝</text>
    <text class="empty-text">数据加载失败</text>
  </view>
</view>
