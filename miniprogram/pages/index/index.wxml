<side-menu
  show-menu="{{showMenu}}"
  user-stamps="{{userStamps}}"
  heatmap-data="{{heatmapData}}"
  bind:close="closeSideMenu"
  bind:themeChanged="onThemeChanged"
  bind:fontSizeChanged="onThemeChanged"
/>

<view class="container {{themeClass}} {{fontClass}}">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-right: {{navbarPaddingRight}}px;">
    <text class="menu-toggle" bindtap="toggleSideMenu">☰</text>
    <text class="navbar-title">我的分析</text>
    <view class="navbar-actions">
      <text class="search-icon" bindtap="showSearchInput">🔍</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view wx:if="{{showSearch}}" class="search-container">
    <input
      class="search-input"
      placeholder="搜索分析记录..."
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      focus="{{searchFocus}}"
    />
    <text class="search-close" bindtap="hideSearchInput">✕</text>
  </view>

  <!-- 领域卡片网格 -->
  <view wx:if="{{showDomainCards}}" class="domain-section">
    <view class="domain-header">
      <text class="domain-header-title">知识全景图</text>
      <view class="domain-header-right">
        <text class="domain-graph-btn" bindtap="goToKnowledgeMap">🗺️ 图谱</text>
        <text class="domain-toggle" bindtap="toggleDomainCards">收起</text>
      </view>
    </view>
    <view class="domain-grid">
      <view
        wx:for="{{domains}}"
        wx:key="id"
        class="domain-card"
        style="border-left: 4rpx solid {{item.color}};"
        bindtap="goToDomain"
        data-id="{{item.id}}"
      >
        <text class="domain-icon">{{item.icon}}</text>
        <text class="domain-name">{{item.name}}</text>
        <text class="domain-count">{{item.methods.length}}种方法</text>
        <text wx:if="{{item.count > 0}}" class="domain-used">已分析{{item.count}}次</text>
      </view>
    </view>
  </view>
  <view wx:if="{{!showDomainCards}}" class="domain-collapsed">
    <text class="domain-toggle" bindtap="toggleDomainCards">展开知识全景图</text>
  </view>

  <!-- 浮动添加按钮菜单 -->
  <view class="float-menu-container">
    <!-- 菜单选项 -->
    <view class="float-menu {{showFloatMenu ? 'show' : ''}}">
      <view class="float-menu-item" bindtap="goToWriteLetter">
        <text class="menu-icon">🔍</text>
        <text class="menu-text">分析方法</text>
      </view>
      <view class="float-menu-item" bindtap="goToRoundtable">
        <text class="menu-icon">👥</text>
        <text class="menu-text">多维度分析</text>
      </view>
      <view class="float-menu-item" bindtap="goToIncubator">
        <text class="menu-icon">💡</text>
        <text class="menu-text">思想孵化器</text>
      </view>
      <view class="float-menu-item" bindtap="goToStructureAnalysis">
        <text class="menu-icon">🔬</text>
        <text class="menu-text">结构分析</text>
      </view>
    </view>
    <!-- 主按钮 -->
    <view class="float-add-button {{showFloatMenu ? 'active' : ''}}" bindtap="toggleFloatMenu">
      <text class="float-add-icon">+</text>
    </view>
  </view>

  <!-- 笔记列表 -->
  <scroll-view 
    scroll-y="true" 
    class="notes-list" 
    scroll-with-animation="{{true}}"
    lower-threshold="100"
    bindscrolltolower="onScrollToLower"
  >
    <view wx:if="{{displayItems.length === 0}}" class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-text">还没有分析记录</text>
      <text class="empty-subtext">点击右上角 + 开始第一次分析</text>
    </view>

    <view
      wx:for="{{displayItems}}"
      wx:key="_id"
      class="note-card"
      bindtap="goToDetail"
      bindlongpress="deleteItem"
      data-id="{{item._id}}"
      data-type="{{item.type}}"
    >
      <view class="note-card-header">
        <view class="note-tags">
          <text class="tag {{item.tagClass || 'tag-blue'}}">{{item.tagText || '分析方法'}}</text>
        </view>
        <view class="note-content-preview">{{item.content}}</view>
      </view>

      <view class="note-footer">
        <text class="note-date">{{item.displayDate || '刚刚'}}</text>
        <text wx:if="{{item.mentor}}" class="note-mentor">{{item.mentor}}</text>
        <text wx:if="{{item.mentors && item.mentors.length > 0}}" class="note-mentors">{{item.mentors.length}}种方法</text>
      </view>
    </view>
    
    <!-- 加载提示 -->
    <view class="loading-footer">
      <view wx:if="{{isLoadingMore}}" class="loading-tip">
        <view class="loading-spinner"></view>
        <text>加载中...</text>
      </view>
      <view wx:elif="{{!hasMore && letters.length > 0}}" class="no-more-tip">
        <text>已加载全部记录</text>
      </view>
    </view>
  </scroll-view>
</view>
