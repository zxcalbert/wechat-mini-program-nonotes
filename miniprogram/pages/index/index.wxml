<side-menu
  show-menu="{{showMenu}}"
  user-stamps="{{userStamps}}"
  heatmap-data="{{heatmapData}}"
  bind:close="closeSideMenu"
/>

<view class="container">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar">
    <text class="menu-toggle" bindtap="toggleSideMenu">☰</text>
    <text class="navbar-title">我的笔记</text>
    <view class="navbar-actions">
      <text class="theme-toggle" bindtap="toggleTheme">{{themeIcon}}</text>
      <text class="search-icon" bindtap="showSearchInput">🔍</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view wx:if="{{showSearch}}" class="search-container">
    <input
      class="search-input"
      placeholder="搜索笔记..."
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      focus="{{searchFocus}}"
    />
    <text class="search-close" bindtap="hideSearchInput">✕</text>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="float-add-button" bindtap="goToWrite">
    <text class="float-add-icon">+</text>
  </view>

  <!-- 笔记列表 -->
  <scroll-view scroll-y="true" class="notes-list" scroll-with-animation="{{true}}">
    <view wx:if="{{displayLetters.length === 0}}" class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-text">还没有笔记呢</text>
      <text class="empty-subtext">点击右上角 + 开始写第一篇</text>
    </view>

    <view
      wx:for="{{displayLetters}}"
      wx:key="_id"
      class="note-card"
      bindtap="goToDetail"
      bindlongpress="deleteLetter"
      data-id="{{item._id}}"
    >
      <view class="note-content-preview">{{item.content}}</view>

      <view class="note-footer">
        <text class="note-date">{{item.displayDate || '刚刚'}}</text>
      </view>
    </view>
  </scroll-view>
</view>
