<view class="container {{themeClass}}">
  <view class="header" style="padding-top: {{statusBarHeight + 10}}px;">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">圆桌会议</view>
    <view class="header-spacer"></view>
  </view>

  <!-- 功能开发中提示 -->
  <view wx:if="{{!featureEnabled}}" class="feature-disabled-mask">
    <view class="feature-disabled-content">
      <text class="feature-disabled-icon">🚧</text>
      <text class="feature-disabled-text">功能正在开发中</text>
      <text class="feature-disabled-subtitle">敬请期待</text>
    </view>
  </view>

  <view class="content">
    <view class="date-section">
      <text class="date-text">{{currentDate}}</text>
    </view>

    <view class="mentor-section">
      <view class="section-title">选择导师（3-5位）</view>
      <view class="selected-count">已选：{{selectedMentors.length}}/5</view>
      
      <view class="mentor-domains">
        <block wx:for="{{mentorsByDomain}}" wx:key="*this">
          <view class="domain-section">
            <view class="domain-title">{{index}}</view>
            <view class="mentor-list">
              <view 
                wx:for="{{item}}" 
                wx:for-item="mentor" 
                wx:key="*this"
                class="mentor-item mentor-item-{{mentor}} {{selectedMentorsMap[mentor] ? 'selected mentor-selected' : ''}}"
                data-mentor="{{mentor}}"
                bindtap="toggleMentor"
              >
                <text class="mentor-name {{selectedMentorsMap[mentor] ? 'mentor-name-selected' : ''}}">{{mentor}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="input-section">
      <view class="section-title">写下你的问题</view>
      <textarea 
        class="content-input" 
        placeholder="在这里写下你想讨论的问题，让多位导师从不同角度为你分析..."
        value="{{content}}"
        bindinput="onInput"
        maxlength="500"
        auto-height
      ></textarea>
      <view class="word-count">{{wordCount}}/500</view>
    </view>

    <view class="submit-section">
      <view class="stamp-info">
        <text class="stamp-icon">🎫</text>
        <text class="stamp-text">消耗3张邮票（当前：{{userStamps}}张）</text>
      </view>
      <button 
        class="submit-btn {{!canSubmit ? 'disabled' : ''}}"
        bindtap="handleSubmit"
        disabled="{{!canSubmit}}"
      >
        {{featureEnabled ? '开始圆桌讨论' : '功能开发中'}}
      </button>
    </view>
  </view>
</view>
