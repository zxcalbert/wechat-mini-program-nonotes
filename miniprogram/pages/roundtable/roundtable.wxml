<view class="page">
  <view class="hero">
    <view class="eyebrow">多维度思考工具</view>
    <view class="title">多维度分析</view>
    <view class="subtitle">选择3-5种分析方法，从不同维度深入分析你的问题。</view>
  </view>

  <view class="panel">
    <view class="label">选择分析方法（3-5种）</view>
    <view class="method-fields">
      <view wx:for="{{methodsByDomain}}" wx:for-index="domain" wx:for-item="methods" wx:key="domain" class="method-field">
        <view class="field-header">
          <text class="field-name">{{domain}}</text>
        </view>
        <view class="method-tags">
          <view
            wx:for="{{methods}}"
            wx:for-item="method"
            wx:key="*this"
            class="method-tag {{selectedMethodsMap[method] ? 'selected' : ''}}"
            data-method="{{method}}"
            bindtap="toggleMethod"
          >{{method}}</view>
        </view>
      </view>
    </view>
    <view class="selected-info">
      <view class="selected-count">
        <text class="count-label">已选方法</text>
        <text class="count-number">{{selectedMethods.length}}/5</text>
      </view>
      <view class="selected-list">
        <text>{{selectedMethods.length > 0 ? selectedMethods.join('、') : '请点击上方方法标签进行选择'}}</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="label">需要分析的内容</view>
    <textarea
      class="content-input"
      placeholder="请输入需要分析的问题或内容..."
      maxlength="2000"
      bindinput="onInput"
      value="{{content}}"
    />
    <view class="word-count">{{wordCount}}/2000字</view>
  </view>

  <view wx:if="{{hasSensitiveWarning}}" class="sensitive-warning">
    <text class="warning-icon">⚠️</text>
    <text class="warning-text">{{sensitiveWarning}}</text>
  </view>

  <view class="panel">
    <view class="label">分析选项</view>
    <view class="stamps-info">
      <text class="stamps-text">本次分析消耗 3 次额度（当前：{{userStamps}}次）</text>
    </view>
  </view>

  <view class="submit-bar">
    <button class="submit-btn {{!canSubmit ? 'disabled' : ''}}" bindtap="handleSubmit" disabled="{{!canSubmit}}">
      🔍 提交多维度分析
    </button>
  </view>
</view>
