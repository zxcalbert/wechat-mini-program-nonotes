page {
  background: #f6f1e8;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
}

.eyebrow {
  font-size: 22rpx;
  color: #8b6b3f;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2b2318;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: #5a4d3a;
}

.panel {
  background: #fffdf8;
  border: 2rpx solid #e2d3bd;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(94, 70, 34, 0.06);
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2b2318;
  margin-bottom: 16rpx;
}

/* 分析方法选择器 - 卡片式领域分组 */
.method-fields {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.method-field {
  background: #f8f2e8;
  border-radius: 16rpx;
  padding: 16rpx;
}

.field-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.field-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.field-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #5a4d3a;
}

.method-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.method-tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #d4c4a8;
  color: #5a4d3a;
  font-size: 24rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.method-tag.selected {
  background: #1f6f5f !important;
  border-color: #1f6f5f !important;
  color: #fff !important;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(31, 111, 95, 0.3);
  transform: scale(1.02);
}

.selected-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #e2d3bd;
}

.selected-count {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.count-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2b2318;
}

.count-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f6f5f;
  background: #e8f5f1;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.selected-list {
  font-size: 24rpx;
  color: #5a4d3a;
  line-height: 1.6;
  padding: 12rpx 16rpx;
  background: #f8f2e8;
  border-radius: 12rpx;
  min-height: 40rpx;
}

/* 输入区域 */
.input-section {
  margin-bottom: 20rpx;
}

.content-input {
  width: 100%;
  min-height: 220rpx;
  background: #f8f2e8;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.7;
  color: #2b2318;
  margin-bottom: 20rpx;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #8b6b3f;
  margin-top: 8rpx;
}

/* 额度信息 */
.stamps-info {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #e8f5f1;
  border-left: 4rpx solid #1f6f5f;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.stamps-text {
  font-size: 24rpx;
  color: #1f6f5f;
  line-height: 1.6;
}

/* 敏感词警告 */
.sensitive-warning {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  background: #fff3cd;
  border: 2rpx solid #ffc107;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.warning-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.warning-text {
  font-size: 26rpx;
  color: #856404;
  line-height: 1.6;
}

/* 提交按钮 */
.submit-bar {
  padding: 20rpx 0 40rpx;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: #1f6f5f;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.submit-btn:active {
  background: #185c4e;
}

.submit-btn.disabled {
  background: #ccc;
  cursor: not-allowed;
}

/* 功能开发中遮罩 */
.feature-disabled-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(43, 35, 24, 0.4);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-disabled-content {
  text-align: center;
  background: #fffdf8;
  padding: 40rpx 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(94, 70, 34, 0.15);
  border: 2rpx solid #e2d3bd;
}

.feature-disabled-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

.feature-disabled-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #2b2318;
  display: block;
  margin-bottom: 8rpx;
}

.feature-disabled-subtitle {
  font-size: 26rpx;
  color: #5a4d3a;
  display: block;
}
