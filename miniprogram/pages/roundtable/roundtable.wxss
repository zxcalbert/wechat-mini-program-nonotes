page {
  background-color: var(--backgroundColor, #ffffff);
}

.container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  background-color: var(--backgroundColor, #ffffff);
  padding-top: env(safe-area-inset-top);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 10px;
  padding-right: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--borderColor, #f0f0f0);
  background-color: var(--backgroundColor, #ffffff);
}

.back-btn {
  font-size: 24px;
  padding: 8px 10px;
  cursor: pointer;
  color: var(--textColor, #000000);
}

.back-icon {
  font-size: 28px;
}

.header-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--textColor, #000000);
  flex: 1;
  text-align: center;
}

.header-spacer {
  width: 40px;
}

.content {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
}

.date-section {
  margin-bottom: 20px;
}

.date-text {
  font-size: 14px;
  color: var(--secondaryTextColor, #999999);
}

.mentor-section {
  margin-bottom: 24px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--textColor, #000000);
  margin-bottom: 8px;
}

.selected-count {
  font-size: 13px;
  color: var(--highlightColor, #8b4513);
  margin-bottom: 12px;
}

.mentor-domains {
  margin-top: 16px;
}

.domain-section {
  margin-bottom: 20px;
}

.domain-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--secondaryTextColor, #666666);
  margin-bottom: 10px;
}

.mentor-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.mentor-item {
  padding: 8px 16px;
  background-color: var(--borderColor, #f5f5f5);
  border: 1px solid var(--borderColor, #eeeeee);
  border-radius: 20px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.mentor-item:active {
  opacity: 0.8;
}

.mentor-item.selected,
.mentor-item.mentor-selected,
.mentor-item[selected="true"] {
  background-color: #8b4513 !important;
  border: 2px solid #8b4513 !important;
  box-shadow: 0 2px 8px rgba(139, 69, 19, 0.3);
}

/* 额外的选中样式，提高优先级 */
.mentor-item.mentor-selected {
  background-color: #8b4513;
  border: 2px solid #8b4513;
  box-shadow: 0 2px 8px rgba(139, 69, 19, 0.3);
}

.mentor-name {
  font-size: 13px;
  color: var(--textColor, #333333);
  line-height: 1.4;
}

.mentor-item.selected .mentor-name,
.mentor-item.mentor-selected .mentor-name,
.mentor-item[selected="true"] .mentor-name {
  color: #ffffff !important;
  font-weight: 600;
}

/* 额外的选中文字样式，提高优先级 */
.mentor-name-selected {
  color: #ffffff !important;
  font-weight: 600 !important;
}

.input-section {
  margin-bottom: 24px;
}

.content-input {
  width: 100%;
  min-height: 150px;
  padding: 16px;
  background-color: var(--cardBackgroundColor, #fdfaf2);
  border: 1px solid var(--cardBorderColor, #e0d5b1);
  border-radius: 8px;
  font-size: 14px;
  line-height: 1.8;
  color: var(--textColor, #333333);
  box-sizing: border-box;
}

.word-count {
  text-align: right;
  font-size: 12px;
  color: var(--secondaryTextColor, #999999);
  margin-top: 8px;
}

.submit-section {
  margin-bottom: 40px;
}

.stamp-info {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
  padding: 12px 16px;
  background-color: var(--borderColor, #fafafa);
  border-radius: 8px;
}

.stamp-icon {
  font-size: 18px;
  margin-right: 8px;
}

.stamp-text {
  font-size: 13px;
  color: var(--secondaryTextColor, #666666);
}

.submit-btn {
  width: 100%;
  padding: 16px;
  background-color: #2ecc71;
  color: #ffffff;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
  transition: background-color 0.2s ease;
}

.submit-btn:active {
  background-color: #27ae60;
}

.submit-btn.disabled {
  background-color: #cccccc;
  cursor: not-allowed;
}

/* 功能开发中遮罩 */
.feature-disabled-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-disabled-content {
  text-align: center;
  background-color: rgba(255, 255, 255, 0.95);
  padding: 40px 30px;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
}

.feature-disabled-icon {
  font-size: 60px;
  display: block;
  margin-bottom: 16px;
}

.feature-disabled-text {
  font-size: 18px;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8px;
}

.feature-disabled-subtitle {
  font-size: 14px;
  color: #666666;
  display: block;
}


