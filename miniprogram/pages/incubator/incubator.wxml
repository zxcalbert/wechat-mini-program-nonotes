<view class="page {{themeClass}}">
  <view class="hero">
    <view class="title">思想孵化器</view>
    <view class="subtitle">输入一个初始想法，生成结构化孵化报告。</view>
  </view>

  <view class="panel">
    <view class="label">选择导师（1-3位）</view>
    <view class="mentor-fields">
      <view wx:for="{{mentorFields}}" wx:key="key" class="mentor-field">
        <view class="field-header">
          <text class="field-icon">{{item.icon}}</text>
          <text class="field-name">{{item.name}}</text>
        </view>
        <view class="mentor-tags">
          <view
            wx:for="{{item.mentors}}"
            wx:for-item="mentor"
            wx:key="*this"
            class="mentor-tag {{selectedMentorMap[mentor] ? 'selected' : ''}}"
            data-name="{{mentor}}"
            bindtap="toggleMentor"
          >{{mentor}}</view>
        </view>
      </view>
    </view>
    <view class="selected-info">
      <view class="selected-count">
        <text class="count-label">已选导师</text>
        <text class="count-number">{{selectedMentors.length}}/3</text>
      </view>
      <view class="selected-list">
        <text>{{selectedMentors.length > 0 ? selectedMentors.join('、') : '请点击上方导师标签进行选择'}}</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="label">初始想法</view>
    <textarea
      class="input"
      placeholder="例如：我想做一个帮助年轻人建立长期思考习惯的产品"
      maxlength="500"
      auto-height
      value="{{idea}}"
      bindinput="onInput"
    ></textarea>
    <button class="submit" loading="{{loading}}" bindtap="generateReport">生成孵化报告</button>
  </view>

  <view wx:if="{{mentors.length}}" class="panel">
    <view class="label">导师视角</view>
    <view class="tags">
      <view wx:for="{{mentors}}" wx:key="*this" class="tag">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{dimensions.length}}" class="panel">
    <view class="label">固定维度</view>
    <view class="tags">
      <view wx:for="{{dimensions}}" wx:key="*this" class="tag tag-soft">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{report}}" class="panel report-panel">
    <view class="label">孵化报告</view>
    <text selectable class="report">{{report}}</text>
  </view>
</view>
