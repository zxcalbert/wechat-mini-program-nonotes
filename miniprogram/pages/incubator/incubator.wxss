page {
  background: #f6f1e8;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
}

.eyebrow {
  font-size: 22rpx;
  color: #8b6b3f;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2b2318;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: #5a4d3a;
}

.panel {
  background: #fffdf8;
  border: 2rpx solid #e2d3bd;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(94, 70, 34, 0.06);
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2b2318;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  min-height: 220rpx;
  background: #f8f2e8;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.7;
  color: #2b2318;
  margin-bottom: 20rpx;
}

.submit {
  background: #1f6f5f;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #2b2318;
  color: #fff;
  font-size: 24rpx;
}

.tag-soft {
  background: #efe4d0;
  color: #5a4d3a;
}

.report-panel {
  margin-bottom: 48rpx;
}

.report {
  white-space: pre-wrap;
  font-size: 26rpx;
  line-height: 1.9;
  color: #2b2318;
}

.mentor-fields {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mentor-field {
  background: #f8f2e8;
  border-radius: 16rpx;
  padding: 16rpx;
}

.field-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.field-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.field-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #5a4d3a;
}

.mentor-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.mentor-tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #d4c4a8;
  color: #5a4d3a;
  font-size: 24rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
}

.mentor-tag.selected {
  background: #1f6f5f !important;
  border-color: #1f6f5f !important;
  color: #fff !important;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(31, 111, 95, 0.3);
  transform: scale(1.02);
}

.selected-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #e2d3bd;
}

.selected-count {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.count-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2b2318;
}

.count-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f6f5f;
  background: #e8f5f1;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.selected-list {
  font-size: 24rpx;
  color: #5a4d3a;
  line-height: 1.6;
  padding: 12rpx 16rpx;
  background: #f8f2e8;
  border-radius: 12rpx;
  min-height: 40rpx;
}
