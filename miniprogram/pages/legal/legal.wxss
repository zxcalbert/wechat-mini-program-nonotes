.legal-container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
  background-color: var(--backgroundColor, #f5f5f5);
}

.legal-header {
  padding: 40rpx 0 30rpx;
  border-bottom: 1rpx solid var(--borderColor, #e0e0e0);
  margin-bottom: 30rpx;
}

.legal-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--textColor, #333);
  margin-bottom: 16rpx;
}

.legal-date {
  display: block;
  font-size: 24rpx;
  color: var(--secondaryTextColor, #999);
}

.legal-intro {
  margin-bottom: 30rpx;
}

.legal-section {
  margin-bottom: 36rpx;
  padding: 30rpx;
  background: var(--cardBackgroundColor, #ffffff);
  border-radius: 16rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--textColor, #333);
  margin-bottom: 20rpx;
}

.section-subtitle {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--textColor, #333);
  margin: 16rpx 0 10rpx;
}

.legal-text {
  display: block;
  font-size: 28rpx;
  color: var(--secondaryTextColor, #666);
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.legal-text.highlight {
  color: #e74c3c;
  font-weight: 500;
}

.info-table {
  margin: 20rpx 0;
  border: 1rpx solid var(--borderColor, #e0e0e0);
  border-radius: 8rpx;
  overflow: hidden;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid var(--borderColor, #e0e0e0);
}

.table-row:last-child {
  border-bottom: none;
}

.table-header {
  background: var(--borderColor, #f0f0f0);
}

.table-header .table-cell {
  font-weight: 600;
  color: var(--textColor, #333);
}

.table-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: var(--secondaryTextColor, #666);
}

.legal-footer {
  text-align: center;
  padding: 50rpx 0;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--secondaryTextColor, #999);
  line-height: 2;
}
