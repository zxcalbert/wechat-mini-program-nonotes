page {
  background-color: var(--backgroundColor, #ffffff);
  overflow-x: hidden;
  max-width: 100vw;
}

.container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  background-color: var(--backgroundColor, #ffffff);
  padding-top: env(safe-area-inset-top);
  overflow: hidden;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 10px;
  padding-right: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--borderColor, #f0f0f0);
  background-color: var(--backgroundColor, #ffffff);
}

.back-btn {
  font-size: 24px;
  padding: 8px 10px;
  cursor: pointer;
  color: var(--textColor, #000000);
}

.back-icon {
  font-size: 28px;
}

.header-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--textColor, #000000);
  flex: 1;
  text-align: center;
}

.header-spacer {
  width: 40px;
}

.content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 20px;
}

.user-question {
  margin-bottom: 24px;
  padding: 16px;
  background-color: var(--cardBackgroundColor, #fdfaf2);
  border: 1px solid var(--cardBorderColor, #e0d5b1);
  border-radius: 8px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--textColor, #000000);
  margin-bottom: 12px;
}

.question-text {
  font-size: 15px;
  line-height: 1.8;
  color: var(--textColor, #333333);
}

.discussion-structure {
  margin-bottom: 24px;
  padding: 16px;
  background-color: var(--cardBackgroundColor, #f0f7ff);
  border: 1px solid var(--cardBorderColor, #b8d4f0);
  border-radius: 8px;
}

.subsection-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--textColor, #000000);
  margin-bottom: 10px;
  margin-top: 16px;
}

.subsection-title:first-child {
  margin-top: 0;
}

.summary-section {
  margin-bottom: 8px;
}

.summary-text {
  font-size: 14px;
  line-height: 1.7;
  color: var(--textColor, #444444);
}

.insights-section {
  margin-bottom: 8px;
}

.keywords-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.keyword-tag {
  display: inline-block;
  padding: 4px 12px;
  background-color: #3498db;
  color: #ffffff;
  font-size: 13px;
  border-radius: 12px;
}

.points-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.point-item {
  display: flex;
  align-items: flex-start;
}

.point-icon {
  font-size: 16px;
  margin-right: 8px;
  margin-top: 1px;
}

.point-text {
  flex: 1;
  font-size: 14px;
  line-height: 1.6;
  color: var(--textColor, #444444);
}

.mentor-list {
  margin-bottom: 24px;
}

.mentor-card {
  margin-bottom: 16px;
  padding: 16px;
  background-color: var(--cardBackgroundColor, #fefefe);
  border: 1px solid var(--cardBorderColor, #e8e8e8);
  border-radius: 8px;
}

.mentor-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.mentor-name {
  font-size: 17px;
  font-weight: 600;
  color: var(--textColor, #000000);
  margin-right: 12px;
}

.mentor-field {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 12px;
  color: #ffffff;
}

.mentor-reply {
  font-size: 15px;
  line-height: 1.8;
  color: var(--textColor, #333333);
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: break-word;
}

.action-buttons {
  display: flex;
  gap: 12px;
}

.action-btn {
  flex: 1;
  padding: 14px;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 600;
}

.export-btn {
  background-color: #3498db;
  color: #ffffff;
}

.share-btn {
  background-color: #2ecc71;
  color: #ffffff;
}

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--borderColor, #e0e0e0);
  border-top-color: #3498db;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 16px;
  font-size: 15px;
  color: var(--textColor, #666666);
}

.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 16px;
  color: var(--textColor, #666666);
}
