page {
  background: #f6f1e8;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
}

.eyebrow {
  font-size: 22rpx;
  color: #8b6b3f;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2b2318;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: #5a4d3a;
}

.panel {
  background: #fffdf8;
  border: 2rpx solid #e2d3bd;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(94, 70, 34, 0.06);
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2b2318;
  margin-bottom: 16rpx;
}

.type-switch {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  border-radius: 16rpx;
  background: #f8f2e8;
  color: #5a4d3a;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-option.active {
  background: #1f6f5f;
  color: #fff;
  border-color: #1f6f5f;
}

.input {
  width: 100%;
  min-height: 280rpx;
  background: #f8f2e8;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.7;
  color: #2b2318;
  margin-bottom: 20rpx;
}

.submit {
  background: #1f6f5f;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #2b2318;
  color: #fff;
  font-size: 24rpx;
}

.tag-soft {
  background: #efe4d0;
  color: #5a4d3a;
}

.report-panel {
  margin-bottom: 48rpx;
}

.report {
  white-space: pre-wrap;
  font-size: 26rpx;
  line-height: 1.9;
  color: #2b2318;
}
