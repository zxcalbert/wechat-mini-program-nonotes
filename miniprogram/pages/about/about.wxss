.about-container {
  padding: 40rpx;
  min-height: 100vh;
  background-color: var(--backgroundColor, #f5f5f5);
}

.about-header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.app-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--textColor, #333);
}

.app-version {
  display: block;
  font-size: 28rpx;
  color: var(--secondaryTextColor, #999);
  margin-top: 12rpx;
}

.about-section {
  margin-bottom: 40rpx;
  padding: 30rpx;
  background: var(--cardBackgroundColor, #ffffff);
  border-radius: 16rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--textColor, #333);
  margin-bottom: 20rpx;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: var(--secondaryTextColor, #666);
  line-height: 1.8;
}

.feature-item {
  display: block;
  font-size: 28rpx;
  color: var(--textColor, #333);
  line-height: 2.2;
}

.about-footer {
  text-align: center;
  padding: 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--secondaryTextColor, #999);
}

.legal-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--borderColor, #f0f0f0);
}

.legal-link:last-child {
  border-bottom: none;
}

.legal-link-text {
  font-size: 28rpx;
  color: var(--textColor, #333);
}

.legal-link-arrow {
  font-size: 28rpx;
  color: var(--secondaryTextColor, #999);
}
